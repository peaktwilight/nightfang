{
  "name": "nightfang",
  "version": "0.1.0",
  "description": "AI-powered red-teaming toolkit for LLM applications",
  "bin": {
    "nightfang": "packages/cli/dist/index.js"
  },
  "files": [
    "LICENSE",
    "README.md",
    "package.json",
    "packages/cli/dist",
    "packages/cli/package.json",
    "packages/core/dist",
    "packages/core/package.json",
    "packages/db/dist",
    "packages/db/package.json",
    "packages/shared/dist",
    "packages/shared/package.json",
    "packages/templates/attacks",
    "packages/templates/dist",
    "packages/templates/package.json"
  ],
  "bundleDependencies": [
    "@nightfang/core",
    "@nightfang/db",
    "@nightfang/shared",
    "@nightfang/templates",
    "better-sqlite3",
    "chalk",
    "commander",
    "drizzle-orm",
    "ora",
    "yaml"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r exec tsc --noEmit",
    "test": "pnpm --filter @nightfang/test-targets test",
    "clean": "pnpm -r clean",
    "vulnerable": "PORT=43100 pnpm --filter @nightfang/test-targets vulnerable",
    "safe": "PORT=43101 pnpm --filter @nightfang/test-targets safe"
  },
  "keywords": [
    "ai",
    "application-security",
    "mcp",
    "owasp",
    "security",
    "red-team",
    "llm",
    "prompt-injection"
  ],
  "author": "Peak Twilight",
  "homepage": "https://github.com/peaktwilight/nightfang#readme",
  "bugs": {
    "url": "https://github.com/peaktwilight/nightfang/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peaktwilight/nightfang.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "dependencies": {
    "@nightfang/core": "file:packages/core",
    "@nightfang/db": "file:packages/db",
    "@nightfang/shared": "file:packages/shared",
    "@nightfang/templates": "file:packages/templates",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "drizzle-orm": "^0.44.0",
    "ora": "^8.0.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  }
}
